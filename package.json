{
  "name": "creators-circle",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "prisma": "turbo run prisma",
    "db:generate": "cd packages/db && npx prisma generate",
    "db:push": "cd packages/db && npx prisma db push",
    "db:seed": "cd packages/db && npx prisma db seed",
    "db:studio": "cd packages/db && npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "node --require ts-node/register prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
