generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role: ADMIN | ARTIST
// Plan: FREE | CREATOR | PRO
// PageType: HOME | BIO | MUSIC | OFFERINGS | CONTACT | CUSTOM | LANDING
// Visibility: PUBLIC | COMMUNITY | PRIVATE

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  avatarUrl            String?
  emailVerified        DateTime?
  role                 String    @default("ARTIST")
  plan                 String    @default("FREE")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  artistProfile        ArtistProfile?
  lanterns             Lantern[]
  rsvps                EventRsvp[]
  accounts             Account[]
  sessions             Session[]
  lanternComments      LanternComment[]
  lanternReactions     LanternReaction[]
}

model ArtistProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistName     String
  slug           String    @unique
  tagline        String?
  bio            String?
  heroImageUrl   String?
  sitePublished  Boolean   @default(false)
  siteTheme      String    @default("sage-dark")
  customDomain   String?
  pages          SitePage[]
  navLinks       NavLink[]
  socialLinks    String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SitePage {
  id             String        @id @default(cuid())
  profileId      String
  profile        ArtistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title          String
  slug           String
  pageType       String        @default("CUSTOM")
  published      Boolean       @default(false)
  sections       String        @default("[]")
  seoTitle       String?
  seoDescription String?
  heroImageUrl   String?
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([profileId, slug])
}

model NavLink {
  id        String        @id @default(cuid())
  profileId String
  profile   ArtistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label     String
  url       String
  order     Int
  openInNew Boolean       @default(false)
}

model Lantern {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  body       String
  imageUrl   String?
  tags       String            @default("[]")
  visibility String            @default("COMMUNITY")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  comments   LanternComment[]
  reactions  LanternReaction[]
}

model LanternComment {
  id        String   @id @default(cuid())
  lanternId String
  lantern   Lantern  @relation(fields: [lanternId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model LanternReaction {
  id        String  @id @default(cuid())
  lanternId String
  lantern   Lantern @relation(fields: [lanternId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String  @default("🔥")

  @@unique([lanternId, userId])
}

model ProgrammingEvent {
  id          String      @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  isVirtual   Boolean     @default(false)
  meetingUrl  String?
  imageUrl    String?
  eventType   String      @default("workshop")
  capacity    Int?
  rsvps       EventRsvp[]
  createdAt   DateTime    @default(now())
}

model EventRsvp {
  id        String           @id @default(cuid())
  eventId   String
  event     ProgrammingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([eventId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
